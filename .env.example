# Copy this file to .env and fill in the values.
# Never commit .env to version control.

# ------------------------------------------------------------------
# Application
# ------------------------------------------------------------------
APP_NAME=github-metadata-service
APP_ENV=development          # development | staging | production
DEBUG=false
LOG_LEVEL=INFO               # DEBUG | INFO | WARNING | ERROR | CRITICAL

# ------------------------------------------------------------------
# Database
# ------------------------------------------------------------------
# Driver must be postgresql+asyncpg (async SQLAlchemy requires asyncpg)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/github_metadata

# Connection pool settings (defaults shown)
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30

# ------------------------------------------------------------------
# GitHub API
# ------------------------------------------------------------------
# Unauthenticated: 60 req/hr  |  Authenticated: 5,000 req/hr
# Create a token at: https://github.com/settings/tokens
# Required scopes: none (public repo metadata only)
GITHUB_TOKEN=your_github_token_here

GITHUB_API_BASE_URL=https://api.github.com
GITHUB_REQUEST_TIMEOUT=10.0

# ------------------------------------------------------------------
# Testing
# ------------------------------------------------------------------
# Separate database used exclusively by the test suite.
# Never set this to the same value as DATABASE_URL.
# Port 5433 matches the docker-compose DB mapping (5433:5432).
TEST_DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5433/github_metadata_test
